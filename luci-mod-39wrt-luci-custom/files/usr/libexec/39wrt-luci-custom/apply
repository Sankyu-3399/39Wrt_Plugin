#!/bin/sh

set -eu

STATUS_SRC="/usr/share/39wrt-luci-custom/status/10_system.js"
FLASH_SRC="/usr/share/39wrt-luci-custom/system/flash.js"
STATUS_DST="/www/luci-static/resources/view/status/include/10_system.js"
FLASH_DST="/www/luci-static/resources/view/system/flash.js"
BACKUP_SUFFIX=".39wrt-luci-custom.bak"

clear_luci_cache() {
	rm -f /tmp/luci-indexcache 2>/dev/null || true
	rm -rf /tmp/luci-modulecache 2>/dev/null || true
}

backup_once() {
	local dst="$1"
	local bak="${dst}${BACKUP_SUFFIX}"

	[ -f "$dst" ] || return 0
	[ -f "$bak" ] || cp -p "$dst" "$bak"
}

install_one() {
	local src="$1"
	local dst="$2"

	if [ ! -f "$src" ]; then
		echo "missing custom source: $src" >&2
		return 1
	fi

	if [ ! -f "$dst" ]; then
		echo "missing LuCI target: $dst" >&2
		return 1
	fi

	backup_once "$dst"
	cp "$src" "$dst"
	chmod 0644 "$dst"
}

restore_one() {
	local dst="$1"
	local bak="${dst}${BACKUP_SUFFIX}"

	[ -f "$bak" ] || return 0
	cp "$bak" "$dst"
	chmod 0644 "$dst"
}

case "${1:-apply}" in
	apply)
		install_one "$STATUS_SRC" "$STATUS_DST"
		install_one "$FLASH_SRC" "$FLASH_DST"
		clear_luci_cache
		;;
	restore)
		restore_one "$STATUS_DST"
		restore_one "$FLASH_DST"
		clear_luci_cache
		;;
	*)
		echo "usage: $0 {apply|restore}" >&2
		exit 1
		;;
esac

exit 0
